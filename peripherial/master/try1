import mne
import gc
from pathlib import Path

SUBJECT_DIR = Path("/home/marta.navarrobernad/Desktop/sub-P02/eeg")
OUT_DIR = SUBJECT_DIR / "GRAND_AVERAGES"
OUT_DIR.mkdir(exist_ok=True, parents=True)

# Canales para limpieza
CH_ESG = ['Iz', 'SC1', 'SC6', 'S3', 'S4', 'S5', 'S6', 'S7', 'S8', 'S9', 
          'S11', 'S12', 'S13', 'S14', 'S15', 'S16', 'S17', 'S18', 'S19']
CH_ERB, CH_AXI = 'ENG_ERB', 'ENG_AXILLA'

def get_thr(epochs, ch_type, minimum):
    data = epochs.get_data(picks=ch_type)
    p2ps = (np.max(data, axis=2) - np.min(data, axis=2)).max(axis=1) * 1e6
    return max(np.percentile(p2ps, 98), minimum)

def generate_ga_fast():
    for f_type in ["GABRIELI", "WIMMER"]:
        for ref in ["TH6", "AC"]:
            files = sorted(list(SUBJECT_DIR.glob(f"*{ref}*{f_type}-epo.fif")))
            if not files: continue

            print(f"\n>>> PROCESANDO GRUPO: {f_type} | {ref}")
            evokeds = []
            
            for f_path in files:
                print(f"    Cargando y limpiando: {f_path.name}")
                # 1. Cargar un solo Run
                epochs = mne.read_epochs(f_path, preload=True, verbose=False)
                epochs.reject = None
                epochs.flat = None
                
                # 2. Baseline real
                epochs.apply_baseline((-0.800, 0), verbose=False)

                # 3. Limpieza adaptativa
                mapping = {ch: ('eeg' if ch in CH_ESG else 'emg' if ch == CH_ERB else 'eog' if ch == CH_AXI else 'misc') 
                           for ch in epochs.ch_names}
                epochs.set_channel_types(mapping, verbose=False)
                
                t_esg = get_thr(epochs, 'eeg', 100)
                t_erb = get_thr(epochs, 'emg', 250)
                t_axi = get_thr(epochs, 'eog', 400)
                
                epochs.drop_bad(reject={'eeg': t_esg*1e-6, 'emg': t_erb*1e-6, 'eog': t_axi*1e-6}, verbose=False)

                # 4. Guardar promedio
                evokeds.append(epochs.average())
                del epochs
                gc.collect()

            # 5. Combinar todos los promedios del grupo
            ga = mne.combine_evoked(evokeds, weights='nave')
            out_name = OUT_DIR / f"GA_{f_type}_{ref}-ave.fif"
            ga.save(out_name, overwrite=True)
            print(f" >> GUARDADO: {out_name.name}")

if __name__ == "__main__":
    import numpy as np # Necesario para get_thr
    generate_ga_fast()
