import mne
import matplotlib.pyplot as plt
import numpy as np
from pathlib import Path

# =============================================================================
# CONFIGURACIÓN DE VISUALIZACIÓN
# =============================================================================
FILTRO = "WIMMER"  # "GABRIELI" o "WIMMER"
REF = "AC"           # "AC" o "TH6"

BASE_DIR = Path("/home/marta.navarrobernad/Desktop/sub-P02/eeg")
GA_DIR = BASE_DIR / "GRAND_AVERAGES_FINAL"

# Canales para la media espinal
CH_SPINAL = ['Iz', 'SC1', 'SC6', 'S3', 'S4', 'S5', 'S6', 'S7', 'S8', 'S9', 
             'S11', 'S12', 'S13', 'S14', 'S15', 'S16', 'S17', 'S18', 'S19']

def plot_combined_multilevel(filt, ref):
    # 1. Definir rutas de los dos archivos necesarios
    path_periph = GA_DIR / f"GA_PERIPH_{ref}_{filt}-ave.fif"
    path_spinal = GA_DIR / f"GA_SPINALS_{ref}_{filt}-ave.fif"

    if not path_periph.exists() or not path_spinal.exists():
        print(f"[-] Faltan archivos para la combinación {ref}-{filt}")
        return

    # 2. Cargar GAs
    ga_pe = mne.read_evokeds(path_periph, verbose=False)[0]
    ga_sp = mne.read_evokeds(path_spinal, verbose=False)[0]

    # 3. Parámetros de ventana según filtro
    if filt == "GABRIELI":
        tmin, tmax, ylim = -0.010, 0.050, (-5, 5)
    else:
        tmin, tmax, ylim = -0.050, 0.400, (-12, 12)

    # Cortar y aplicar baseline
    ga_pe.crop(tmin, tmax).apply_baseline((-0.010, 0))
    ga_sp.crop(tmin, tmax).apply_baseline((-0.010, 0))
    times = ga_pe.times * 1000

    # --- CREAR FIGURA ---
    fig, axes = plt.subplots(3, 1, figsize=(10, 12), sharex=True)
    plt.subplots_adjust(hspace=0.3)

    # PANEL 1: AXILLA
    if 'ENG_AXILLA' in ga_pe.ch_names:
        data_axi = ga_pe.copy().pick('ENG_AXILLA').data[0] * 1e6
        axes[0].plot(times, data_axi, color='seagreen', lw=2)
        axes[0].set_title(f"Nivel 1: Axilla (Periferia) - {ref}", fontweight='bold')
    
    # PANEL 2: ERB
    if 'ENG_ERB' in ga_pe.ch_names:
        data_erb = ga_pe.copy().pick('ENG_ERB').data[0] * 1e6
        axes[1].plot(times, data_erb, color='royalblue', lw=2)
        axes[1].set_title(f"Nivel 2: Punto de Erb - {ref}", fontweight='bold')

    # PANEL 3: MÉDULA (Media de todos los canales espinales)
    present_sp = [c for c in CH_SPINAL if c in ga_sp.ch_names]
    if present_sp:
        data_sp = ga_sp.copy().pick(present_sp).data * 1e6
        # Mariposas (canales individuales en gris)
        for i in range(data_sp.shape[0]):
            axes[2].plot(times, data_sp[i, :], color='gray', alpha=0.2, lw=0.7)
        # Media en rojo
        axes[2].plot(times, np.mean(data_sp, axis=0), color='crimson', lw=2.5, label='Media Espinal')
        axes[2].set_title(f"Nivel 3: Médula Espinal - {ref}", fontweight='bold')
        axes[2].legend(loc='upper right')

    # Estética común
    for ax in axes:
        ax.axvline(0, color='black', ls='--')
        ax.set_ylim(ylim)
        ax.set_ylabel("µV")
        ax.grid(True, alpha=0.2)

    plt.suptitle(f"Trayectoria del Potencial Somatosensorial ({filt})", fontsize=14)
    plt.xlabel("Tiempo (ms)")
    plt.show()

if __name__ == "__main__":
    plot_combined_multilevel(FILTRO, REF)
