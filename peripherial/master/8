import mne
import gc
from pathlib import Path

# =============================================================================
# CONFIGURACIÓN AUTOMÁTICA
# =============================================================================
BASE_DIR = Path("/home/marta.navarrobernad/Desktop/sub-P02/eeg")
OUT_DIR = BASE_DIR / "GRAND_AVERAGES_FINAL"
OUT_DIR.mkdir(exist_ok=True, parents=True)

# Tipos de datos que hemos procesado por separado
DATA_TYPES = ["SPINALS", "PERIPH"]
FILTERS = ["GABRIELI", "WIMMER"]
REFS = ["AC", "TH6"]

def run_final_grand_averages():
    print("--- INICIANDO PROCESADO AUTOMÁTICO DE GRAND AVERAGES ---")
    print(f"Carpeta de salida: {OUT_DIR}\n")

    for dtype in DATA_TYPES:
        clean_dir = BASE_DIR / f"CLEAN_EPOCHS_{dtype}"
        
        if not clean_dir.exists():
            print(f"[!] Saltando {dtype}: La carpeta no existe.")
            continue

        for filt in FILTERS:
            for ref in REFS:
                # El patrón ahora busca el sufijo que pusimos: _TIPO-epo.fif
                pattern = f"CLEANED_{ref}_{filt}_*_{dtype}-epo.fif"
                files = sorted(list(clean_dir.glob(pattern)))

                if not files:
                    # Intento alternativo por si algún archivo no tiene el -epo
                    pattern_alt = f"CLEANED_{ref}_{filt}_*_{dtype}.fif"
                    files = sorted(list(clean_dir.glob(pattern_alt)))
                
                if not files:
                    continue

                print(f"[+] Procesando GA: {dtype} | {ref} | {filt} ({len(files)} archivos)")
                
                all_evokeds = []
                total_epochs = 0

                for f_path in files:
                    try:
                        epochs = mne.read_epochs(f_path, preload=True, verbose=False)
                        
                        if len(epochs) > 0:
                            evoked = epochs.average()
                            # Forzamos que el tipo de canal sea eeg para evitar conflictos al combinar
                            evoked.set_channel_types({ch: 'eeg' for ch in evoked.ch_names})
                            all_evokeds.append(evoked)
                            total_epochs += len(epochs)
                        
                        del epochs
                        gc.collect()
                    except Exception as e:
                        print(f"    [!] Error cargando {f_path.name}: {e}")

                if all_evokeds:
                    # Combinación pesada por el número de épocas de cada Run
                    ga = mne.combine_evoked(all_evokeds, weights='nave')
                    
                    # Nombre final limpio
                    out_name = f"GA_{dtype}_{ref}_{filt}-ave.fif"
                    ga.save(OUT_DIR / out_name, overwrite=True, verbose=False)
                    print(f"    [OK] Guardado: {out_name} (Épocas totales: {total_epochs})")
                else:
                    print(f"    [?] Sin datos válidos para {dtype}-{ref}-{filt}")

    print("\n" + "="*60)
    print("¡LISTO! Todos los Grand Averages se han generado correctamente.")
    print("="*60)

if __name__ == "__main__":
    run_final_grand_averages()
