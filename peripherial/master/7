import mne
import gc
from pathlib import Path

# =============================================================================
# Harcoded porque se me congelaba spyder todo el rato si lo intentaba hacer manual 
# =============================================================================
FILTRO = "GABRIELI"  # Opciones: "GABRIELI" o "WIMMER"
REF = "TH6"         # Opciones: "TH6" o "AC"

# Rutas
BASE_DIR = Path("/home/marta.navarrobernad/Desktop/sub-P02/eeg")
CLEAN_DIR = BASE_DIR / "CLEAN_EPOCHS_FINAL"
OUT_DIR = BASE_DIR / "COMBINED_FILES"
OUT_DIR.mkdir(exist_ok=True, parents=True)

def run_safe_concatenation(filter_type, ref_type):
    # 1. Buscar los archivos CLEANED específicos
    pattern = f"CLEANED_{ref_type}_{filter_type}_*.fif"
    files = sorted(list(CLEAN_DIR.glob(pattern)))

    if not files:
        print(f"[-] No se encontraron archivos para {ref_type} - {filter_type}")
        return

    print(f"\n[+] INICIANDO CONCATENACIÓN: {filter_type} | REF: {ref_type}")
    print(f"    Archivos a unir: {len(files)}")

    # 2. Cargar el primer archivo como base del bloque
    print(f"    -> Cargando base: {files[0].name}")
    combined = mne.read_epochs(files[0], preload=True, verbose=False)
    
    # Unificamos IDs y reseteamos metadatos de rechazo para evitar errores de MNE
    combined.events[:, 2] = 1
    combined.event_id = {'All_Stimuli': 1}
    combined.reject = None
    combined.flat = None

    # 3. Bucle de anexión uno a uno
    for f_path in files[1:]:
        print(f"    -> Añadiendo: {f_path.name}")
        temp_epo = mne.read_epochs(f_path, preload=True, verbose=False)
        
        # Sincronizar metadatos antes de unir
        temp_epo.events[:, 2] = 1
        temp_epo.event_id = {'All_Stimuli': 1}
        temp_epo.reject = None
        temp_epo.flat = None
        
        # Concatenar al bloque principal
        combined = mne.concatenate_epochs([combined, temp_epo], on_mismatch='ignore')
        
        # LIBERACIÓN TOTAL DE RAM del archivo temporal
        del temp_epo
        gc.collect()

    # 4. Guardar el archivo gigante resultante
    out_name = f"FULL_COMBINED_{ref_type}_{filter_type}-epo.fif"
    print(f"\n[!] Guardando archivo final: {out_name}...")
    
    # Usamos verbose=True para ver el progreso del guardado en disco
    combined.save(OUT_DIR / out_name, overwrite=True, verbose=True)
    
    print(f" >> ÉXITO: {out_name} creado con {len(combined)} épocas.")
    
    # Limpiar RAM final
    del combined
    gc.collect()

if __name__ == "__main__":
    run_safe_concatenation(FILTRO, REF)
