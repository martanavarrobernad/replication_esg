import mne
import gc
import numpy as np
from pathlib import Path

# =============================================================================
# Harcoded porque estaba teniendo muchos problemas con la RAM al automatizar 
# =============================================================================
FILTRO = "GABRIELI"  # Prueba con uno y luego con otro
REF = "AC"

BASE_DIR = Path("/home/marta.navarrobernad/Desktop/sub-P02/eeg")
CLEAN_DIR = BASE_DIR / "CLEAN_EPOCHS_FINAL"
OUT_DIR = BASE_DIR / "GRAND_AVERAGES"
OUT_DIR.mkdir(exist_ok=True, parents=True)

def generate_grand_average_safe(filter_type, ref_type):
    # Buscamos los archivos CLEANED
    pattern = f"CLEANED_{ref_type}_{filter_type}_*.fif"
    files = sorted(list(CLEAN_DIR.glob(pattern)))

    if not files:
        print(f"[-] No hay archivos para {ref_type}-{filter_type}")
        return

    print(f"\n[+] PROCESANDO: {filter_type} | {ref_type}")
    
    all_evokeds = []
    total_epochs_count = 0

    for f_path in files:
        print(f"    -> Extrayendo promedio de: {f_path.name}")
        # Cargamos, promediamos y soltamos RAM inmediatamente
        epochs = mne.read_epochs(f_path, preload=True, verbose=False)
        
        n_epochs = len(epochs)
        total_epochs_count += n_epochs
        
        # Guardamos el promedio individual
        evoked = epochs.average()
        all_evokeds.append(evoked)
        
        del epochs
        gc.collect()

    # Combinamos todos los promedios pesados por su número de épocas
    # Esto es exactamente lo mismo que promediar el archivo concatenado
    grand_average = mne.combine_evoked(all_evokeds, weights='nave')

    # Guardamos el resultado final
    out_name = f"GRAND_AVERAGE_{ref_type}_{filter_type}-ave.fif"
    grand_average.save(OUT_DIR / out_name, overwrite=True)
    
    print(f"\n[OK] ÉXITO TOTAL:")
    print(f"     - Archivo guardado: {out_name}")
    print(f"     - Épocas totales analizadas: {total_epochs_count}")

if __name__ == "__main__":
    generate_grand_average_safe(FILTRO, REF)
