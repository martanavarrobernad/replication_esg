import mne
import numpy as np
from pathlib import Path
import gc
import pandas as pd
from collections import Counter

# =============================================================================
# CONFIGURATION - PERIPHERAL ONLY
# =============================================================================
BASE_DIR = Path("/home/marta.navarrobernad/Desktop/sub-P02/eeg")
INPUT_FILES = sorted(list(BASE_DIR.glob("*_GABRIELI-epo.fif")) + list(BASE_DIR.glob("*_WIMMER-epo.fif")))
OUT_DIR = BASE_DIR / "CLEAN_EPOCHS_PERIPHERAL"
REPORT_DIR = BASE_DIR / "REPORTS_CLEANING_PERIPH"

OUT_DIR.mkdir(exist_ok=True, parents=True)
REPORT_DIR.mkdir(exist_ok=True, parents=True)

CH_PERIPH = ['ENG_ERB', 'ENG_AXILLA']

def get_thr(epochs, picks, minimum):
    """Calculates adaptive threshold for peripheral channels."""
    try:
        data = epochs.get_data(picks=picks)
        if data.size == 0: return minimum
        p2ps = (np.max(data, axis=2) - np.min(data, axis=2)).max(axis=1) * 1e6
        return max(np.percentile(p2ps, 98), minimum)
    except:
        return minimum

def main_peripheral_cleaning():
    print("--- Starting Peripheral (Erb/Axilla) Cleaning Process ---")
    
    for f_path in INPUT_FILES:
        print(f"\n>> Opening file: {f_path.name}")
        epochs = mne.read_epochs(f_path, preload=True, verbose=False)
        n_before = len(epochs)
        
        ref = "TH6" if "RefTH6" in f_path.name else "AC" if "RefAC" in f_path.name else "UNK"
        filt_type = "GABRIELI" if "GABRIELI" in f_path.name else "WIMMER"

        # 1. Quedarse solo con los periféricos
        picks_pe = [ch for ch in CH_PERIPH if ch in epochs.ch_names]
        if not picks_pe:
            print(f"   [!] No peripheral channels found in {f_path.name}")
            continue
        
        epochs.pick(picks_pe)

        # 2. Reset a 'eeg' para evitar problemas de visualización/promediado
        epochs.set_channel_types({ch: 'eeg' for ch in picks_pe}, verbose=False)

        # 3. Umbrales adaptativos (con suelo de 250 para Erb y 400 para Axilla)
        # Calculamos un umbral global para los periféricos presentes
        t_pe = get_thr(epochs, picks_pe, 250 if filt_type == "GABRIELI" else 400)

        # 4. Drop Bad
        epochs.drop_bad(reject={'eeg': t_pe * 1e-6}, verbose=False)
        n_after = len(epochs)
        
        # 5. Reporte (Filtrando el historial antiguo de ECG para ver solo ruido nuevo)
        # Solo mostramos en el log los canales que han superado el umbral ahora
        reasons = [ch for log in epochs.drop_log if log for ch in log if ch in picks_pe]
        counts = Counter(reasons)
        top_str = "; ".join([f"{ch}({n})" for ch, n in counts.most_common()])

        print(f"   Ref: {ref} | Filter: {filt_type} | Threshold: {t_pe:.1f} uV")
        print(f"   Survival: {n_after}/{n_before} (Dropped: {n_before - n_after})")
        print(f"   New Noise Sources: {top_str if top_str else 'None'}")

        # 6. Save
        out_name = f"CLEANED_{ref}_{filt_type}_{f_path.stem}_PERIPH-epo.fif"
        epochs.save(OUT_DIR / out_name, overwrite=True, verbose=False)
        
        del epochs
        gc.collect()

    print("\n--- PERIPHERAL CLEANING COMPLETED ---")

if __name__ == "__main__":
    main_peripheral_cleaning()
