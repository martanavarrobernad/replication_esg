import mne
import numpy as np
from pathlib import Path
import gc

# =============================================================================
# CONFIGURACIÓN LIMPIEZA ADAPTATIVA
# =============================================================================
BASE_DIR = Path("/home/marta.navarrobernad/Desktop/sub-P02/eeg")
# Coge todos los archivos generados en el paso anterior
INPUT_FILES = sorted(list(BASE_DIR.glob("*_GABRIELI-epo.fif")) + list(BASE_DIR.glob("*_WIMMER-epo.fif")))

OUT_DIR = BASE_DIR / "CLEAN_EPOCHS_FINAL"
OUT_DIR.mkdir(exist_ok=True, parents=True)

CH_ESG_BASE = ['Iz', 'SC1', 'SC6', 'S3', 'S4', 'S5', 'S6', 'S7', 'S8', 'S9', 
                'S11', 'S12', 'S13', 'S14', 'S15', 'S16', 'S17', 'S18', 'S19']
CH_ERB = 'ENG_ERB'
CH_AXI = 'ENG_AXILLA'

def get_thr(epochs, ch_type, minimum):
    try:
        data = epochs.get_data(picks=ch_type)
        if data.size == 0: return minimum
        p2ps = (np.max(data, axis=2) - np.min(data, axis=2)).max(axis=1) * 1e6
        return max(np.percentile(p2ps, 98), minimum)
    except:
        return minimum

def survival_cleaning_robust():
    for f_path in INPUT_FILES:
        print(f"\n[+] Limpieza Robusta (Percentil 98): {f_path.name}")
        epochs = mne.read_epochs(f_path, preload=True, verbose=False)
        
        # Backup de tipos originales (Seguridad para Spinal/Erb/Axilla)
        original_types = {ch: epochs.get_channel_types(picks=[ch])[0] for ch in epochs.ch_names}

        # Mapeo temporal para rechazo diferenciado
        mapping = {}
        for ch in epochs.ch_names:
            if ch in CH_ESG_BASE: mapping[ch] = 'eeg'
            elif ch == CH_ERB: mapping[ch] = 'emg'
            elif ch == CH_AXI: mapping[ch] = 'eog'
            else: mapping[ch] = 'misc'
        epochs.set_channel_types(mapping, verbose=False)

        # Umbrales
        t_esg = get_thr(epochs, 'eeg', 100)
        t_erb = get_thr(epochs, 'emg', 250)
        t_axi = get_thr(epochs, 'eog', 400)

        # Rechazo
        n_pre = len(epochs)
        epochs.drop_bad(reject={'eeg': t_esg*1e-6, 'emg': t_erb*1e-6, 'eog': t_axi*1e-6}, verbose=False)
        print(f"    ESG thr: {t_esg:.1f} | ERB thr: {t_erb:.1f} | AXILLA thr: {t_axi:.1f}")
        print(f"    -> Épocas eliminadas: {n_pre - len(epochs)}")

        # RESTAURAR TIPOS ORIGINALES
        epochs.set_channel_types(original_types, verbose=False)

        # Guardado final
        out_path = OUT_DIR / f"{f_path.stem}_CLEANED-epo.fif"
        epochs.save(out_path, overwrite=True, verbose=False)
        
        del epochs
        gc.collect()

if __name__ == "__main__":
    survival_cleaning_robust()
