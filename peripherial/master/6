import mne
import numpy as np
from pathlib import Path
import gc

# =============================================================================
# CONFIGURACIÓN ESPINAL
# =============================================================================
BASE_DIR = Path("/home/marta.navarrobernad/Desktop/sub-P02/eeg")
INPUT_FILES = sorted(list(BASE_DIR.glob("*_GABRIELI-epo.fif")) + list(BASE_DIR.glob("*_WIMMER-epo.fif")))
OUT_DIR = BASE_DIR / "CLEAN_EPOCHS_SPINALS"
OUT_DIR.mkdir(exist_ok=True, parents=True)

CH_SPINAL = ['Iz', 'SC1', 'SC6', 'S3', 'S4', 'S5', 'S6', 'S7', 'S8', 'S9', 
             'S11', 'S12', 'S13', 'S14', 'S15', 'S16', 'S17', 'S18', 'S19']

def get_adaptive_thr(epochs, picks, min_val):
    try:
        data = epochs.get_data(picks=picks)
        if data.size == 0: return min_val
        p2ps = (np.max(data, axis=2) - np.min(data, axis=2)).max(axis=1) * 1e6
        val_98 = np.percentile(p2ps, 98)
        return max(val_98, min_val)
    except:
        return min_val

def process_spinals():
    print("--- INICIANDO LIMPIEZA ESPINAL (ADAPTATIVA) ---")
    for f_path in INPUT_FILES:
        ref = "TH6" if "RefTH6" in f_path.name else "AC" if "RefAC" in f_path.name else "UNK"
        filt = "GABRIELI" if "GABRIELI" in f_path.name else "WIMMER"
        
        epochs = mne.read_epochs(f_path, preload=True, verbose=False)
        
        # Solo nos quedamos con los canales espinales para este archivo
        picks_sp = [ch for ch in CH_SPINAL if ch in epochs.ch_names]
        epochs.pick(picks_sp)
        
        # Umbral adaptativo
        thr = get_adaptive_thr(epochs, picks_sp, 80)
        
        print(f">> {f_path.name} | Ref: {ref} | Umbral: {thr:.1f} µV")
        
        epochs.drop_bad(reject=dict(eeg=thr*1e-6), verbose=False)
        
        # Guardar con sufijo SPINALS
        out_name = f"CLEANED_{ref}_{filt}_{f_path.stem}_SPINALS.fif"
        epochs.save(OUT_DIR / out_name, overwrite=True, verbose=False)
        
        del epochs
        gc.collect()

if __name__ == "__main__":
    process_spinals()
