import mne
import numpy as np
from pathlib import Path
import gc
import pandas as pd
from collections import Counter

# =============================================================================
# CONFIGURATION
# =============================================================================
BASE_DIR = Path("/home/marta.navarrobernad/Desktop/sub-P02/eeg")
# Files from STAGING (before cleaning)
INPUT_FILES = sorted(list(BASE_DIR.glob("*_GABRIELI-epo.fif")) + list(BASE_DIR.glob("*_WIMMER-epo.fif")))
OUT_DIR = BASE_DIR / "CLEAN_EPOCHS_SPINALS"
REPORT_DIR = BASE_DIR / "REPORTS_CLEANING"

OUT_DIR.mkdir(exist_ok=True, parents=True)
REPORT_DIR.mkdir(exist_ok=True, parents=True)

# Channel Groups
CH_ESG_BASE = ['Iz', 'SC1', 'SC6', 'S3', 'S4', 'S5', 'S6', 'S7', 'S8', 'S9', 
               'S11', 'S12', 'S13', 'S14', 'S15', 'S16', 'S17', 'S18', 'S19']
CH_ERB = ['ENG_ERB']
CH_AXI = ['ENG_AXILLA']

def get_thr(epochs, ch_type, minimum):
    """Calculates adaptive threshold for a specific channel type (EEG, EMG, EOG)."""
    try:
        # We pick only the channels defined for this type
        data = epochs.copy().pick_types(**{ch_type: True}).get_data()
        if data.size == 0: return minimum
        # Calculate Peak-to-Peak (PTP) per epoch
        p2ps = (np.max(data, axis=2) - np.min(data, axis=2)).max(axis=1) * 1e6
        return max(np.percentile(p2ps, 98), minimum)
    except:
        return minimum

def main_cleaning_by_filter():
    print("--- Starting Cleaning Process based on Filter Type ---")
    
    for f_path in INPUT_FILES:
        print(f"\n>> Opening file: {f_path.name}")
        
        # 1. Load Original Epochs
        epochs = mne.read_epochs(f_path, preload=True, verbose=False)
        n_before = len(epochs)
        
        # 2. Identify Filter and Reference from Filename
        ref = "TH6" if "RefTH6" in f_path.name else "AC" if "RefAC" in f_path.name else "UNK"
        filt_type = "GABRIELI" if "GABRIELI" in f_path.name else "WIMMER"
        
        # 3. Channel Mapping (Critical to prevent Erb/Axilla from contaminating Spinals)
        mapping = {ch: 'misc' for ch in epochs.ch_names}
        for ch in CH_ESG_BASE:
            if ch in mapping: mapping[ch] = 'eeg'
        if CH_ERB[0] in mapping: mapping[CH_ERB[0]] = 'emg'
        if CH_AXI[0] in mapping: mapping[CH_AXI[0]] = 'eog'
        
        epochs.set_channel_types(mapping, verbose=False)

        # 4. Apply Specific Cleaning Logic based on Filter
        # If Wimmer, we are more generous with thresholds due to baseline drift
        if filt_type == "WIMMER":
            t_esg = get_thr(epochs, 'eeg', 150) # Wimmer needs higher floor
            t_erb = get_thr(epochs, 'emg', 300)
            t_axi = get_thr(epochs, 'eog', 450)
        else: # GABRIELI or others
            t_esg = get_thr(epochs, 'eeg', 100)
            t_erb = get_thr(epochs, 'emg', 250)
            t_axi = get_thr(epochs, 'eog', 400)

        # 5. Drop Bad Epochs
        reject_criteria = {
            'eeg': t_esg * 1e-6, 
            'emg': t_erb * 1e-6, 
            'eog': t_axi * 1e-6
        }
        
        epochs.drop_bad(reject=reject_criteria, verbose=False)
        n_after = len(epochs)
        
        # 6. Generate Drop Log Report
        drop_reasons = [ch for log in epochs.drop_log if log for ch in log if ch not in ['IGNORED', 'NO_DATA']]
        counts = Counter(drop_reasons)
        top_culprits = "; ".join([f"{ch}({n})" for ch, n in counts.most_common(3)])

        print(f"   Filter Detected: {filt_type} | Ref: {ref}")
        print(f"   Thresholds applied: ESG={t_esg:.1f}, ERB={t_erb:.1f}, AXI={t_axi:.1f}")
        print(f"   Survival: {n_after}/{n_before} (Dropped: {n_before - n_after})")
        print(f"   Top Noisy Channels: {top_culprits}")

        # 7. Save Report CSV
        summary_data = {
            "file": f_path.name,
            "filter": filt_type,
            "reference": ref,
            "remaining_epochs": n_after,
            "perc_rejected": round(((n_before - n_after) / n_before) * 100, 2),
            "thr_esg": t_esg,
            "top_culprits": top_culprits
        }
        pd.DataFrame([summary_data]).to_csv(REPORT_DIR / f"Cleaning_{f_path.stem}.csv", index=False)

        # 8. Save Cleaned File (Keep only Spinal channels for the GA)
        epochs_spinals = epochs.copy().pick_types(eeg=True)
        out_name = f"CLEANED_{ref}_{filt_type}_{f_path.stem}_SPINALS-epo.fif"
        epochs_spinals.save(OUT_DIR / out_name, overwrite=True, verbose=False)
        
        del epochs, epochs_spinals
        gc.collect()

    print("\n--- CLEANING COMPLETED ---")

if __name__ == "__main__":
    main_cleaning_by_filter()
