#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import mne
import matplotlib.pyplot as plt
import numpy as np
from pathlib import Path
from scipy.interpolate import griddata

# =============================================================================
# TU MONTAJE DEFINITIVO (Fijado y Correcto)
# =============================================================================
SPINAL_EXTRA = {
    "Iz":  [0.000, -0.090], 
    "SC1": [0.000, -0.105],
    "S3":  [0.000, -0.120],
    "S6":  [0.000, -0.1325],
    "S7":  [0.010, -0.145], "S5":  [-0.010, -0.145], 
    "SC6": [0.000, -0.160],
    "S11": [0.010, -0.170], "S9":  [-0.010, -0.170], 
    "S14": [0.000, -0.180],
    "S15": [0.010, -0.190], "S13": [-0.010, -0.190], 
    "S18": [0.000, -0.200],
    "S19": [0.010, -0.210], "S17": [-0.010, -0.210],
    "S4":  [-0.050, -0.1325], "S8":  [0.050, -0.1325], 
    "S12": [-0.050, -0.190],  "S16": [0.050, -0.190],
    "AC":  [0.050, -0.100],   "TH6": [0.000, -0.300]
}

# Aplicar shift de 1cm
for ch in SPINAL_EXTRA:
    SPINAL_EXTRA[ch][1] -= 0.01

BASE_DIR = Path("/home/marta.navarrobernad/Desktop/sub-P02/eeg")
GA_PATH = BASE_DIR / "GRAND_AVERAGES_FINAL" / "GA_SPINALS_AC_GABRIELI-ave.fif"

def plot_n13_series_correct_montage():
    if not GA_PATH.exists(): return
    
    evoked = mne.read_evokeds(GA_PATH, verbose=False)[0]
    evoked.apply_baseline((0.000, 0.005), verbose=False)
    
    # Ventana 11-15 ms
    times_to_plot = np.arange(0.011, 0.0155, 0.0005)
    spinal_picks = [ch for ch in SPINAL_EXTRA.keys() if ch in evoked.ch_names]
    points = np.array([SPINAL_EXTRA[ch][:2] for ch in spinal_picks])
    
    fig, axes = plt.subplots(3, 3, figsize=(15, 18))
    axes = axes.flatten()
    
    # Escala fija para todos los mapas (basada en el pico de 13.2 ms)
    v_peak = np.max(np.abs(evoked.copy().pick(spinal_picks).crop(0.011, 0.015).data)) * 1e6

    for i, t in enumerate(times_to_plot):
        v_data = evoked.copy().pick(spinal_picks).crop(t, t).data.flatten() * 1e6
        
        # Interpolación rectangular sobre tu rejilla
        grid_x, grid_y = np.mgrid[-0.06:0.06:150j, -0.25:-0.08:200j]
        grid_z = griddata(points, v_data, (grid_x, grid_y), method='cubic')
        
        im = axes[i].imshow(grid_z.T, extent=(-0.06, 0.06, -0.25, -0.07), origin='lower',
                            cmap='RdBu_r', vmin=-v_peak, vmax=v_peak, aspect='auto')
        
        # Dibujar los electrodos EXACTAMENTE donde están
        for name, (px, py) in SPINAL_EXTRA.items():
            if name in spinal_picks:
                axes[i].plot(px, py, 'ko', markersize=2, alpha=0.4)
        
        axes[i].set_title(f"T = {t*1000:.1f} ms", fontsize=10, fontweight='bold')
        axes[i].axis('off')

    plt.suptitle("SERIE TEMPORAL N13 - MONTAJE REAL P02", fontsize=16, fontweight='bold', y=0.95)
    
    # Barra de color única
    cbar_ax = fig.add_axes([0.92, 0.2, 0.02, 0.6])
    fig.colorbar(im, cax=cbar_ax, label="Amplitud (µV)")
    
    plt.savefig(BASE_DIR / "N13_SERIES_MONTAJE_REAL.png", dpi=300)
    plt.show()

if __name__ == "__main__":
    plot_n13_series_correct_montage()
