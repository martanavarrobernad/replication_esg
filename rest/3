import mne
import numpy as np
from pathlib import Path
import gc
import pandas as pd
from collections import Counter

# =============================================================================
# CONFIGURATION - RESTING STATE SPINALS
# =============================================================================
BASE_DIR = Path("/home/marta.navarrobernad/Desktop/sub-P02/eeg")

# CAMBIO: Buscamos específicamente archivos que tengan REST y el filtro aplicado
INPUT_FILES = sorted(
    list(BASE_DIR.glob("*REST*GABRIELI-epo.fif")) + 
    list(BASE_DIR.glob("*REST*WIMMER-epo.fif"))
)

# CAMBIO: Carpetas de salida exclusivas para REST
OUT_DIR = BASE_DIR / "CLEAN_EPOCHS_REST_SPINALS"
REPORT_DIR = BASE_DIR / "REPORTS_CLEANING_REST"

OUT_DIR.mkdir(exist_ok=True, parents=True)
REPORT_DIR.mkdir(exist_ok=True, parents=True)

# Channel Groups
CH_ESG_BASE = ['Iz', 'SC1', 'SC6', 'S3', 'S4', 'S5', 'S6', 'S7', 'S8', 'S9', 
               'S11', 'S12', 'S13', 'S14', 'S15', 'S16', 'S17', 'S18', 'S19']
CH_ERB = ['ENG_ERB']
CH_AXI = ['ENG_AXILLA']

def get_thr(epochs, ch_type, minimum):
    """Calculates adaptive threshold for a specific channel type."""
    try:
        data = epochs.copy().pick_types(**{ch_type: True}).get_data()
        if data.size == 0: return minimum
        p2ps = (np.max(data, axis=2) - np.min(data, axis=2)).max(axis=1) * 1e6
        return max(np.percentile(p2ps, 98), minimum)
    except:
        return minimum

def main_cleaning_rest_spinals():
    print(f"--- Starting REST Cleaning (Spinals) ---")
    print(f"Archivos encontrados: {len(INPUT_FILES)}")
    
    for f_path in INPUT_FILES:
        print(f"\n>> Opening file: {f_path.name}")
        
        # 1. Load Original Epochs
        epochs = mne.read_epochs(f_path, preload=True, verbose=False)
        n_before = len(epochs)
        
        # 2. Identify Filter and Reference
        ref = "TH6" if "RefTH6" in f_path.name else "AC" if "RefAC" in f_path.name else "UNK"
        filt_type = "GABRIELI" if "GABRIELI" in f_path.name else "WIMMER"
        
        # 3. Channel Mapping
        mapping = {ch: 'misc' for ch in epochs.ch_names}
        for ch in CH_ESG_BASE:
            if ch in mapping: mapping[ch] = 'eeg'
        if CH_ERB[0] in mapping: mapping[CH_ERB[0]] = 'emg'
        if CH_AXI[0] in mapping: mapping[CH_AXI[0]] = 'eog'
        
        epochs.set_channel_types(mapping, verbose=False)

        # 4. Apply Rejection Logic (Misma lógica que SSEP para comparación justa)
        if filt_type == "WIMMER":
            t_esg = get_thr(epochs, 'eeg', 150) 
            t_erb = get_thr(epochs, 'emg', 300)
            t_axi = get_thr(epochs, 'eog', 450)
        else: # GABRIELI
            t_esg = get_thr(epochs, 'eeg', 100)
            t_erb = get_thr(epochs, 'emg', 250)
            t_axi = get_thr(epochs, 'eog', 400)

        reject_criteria = {
            'eeg': t_esg * 1e-6, 
            'emg': t_erb * 1e-6, 
            'eog': t_axi * 1e-6
        }
        
        # 5. Drop Bad
        epochs.drop_bad(reject=reject_criteria, verbose=False)
        n_after = len(epochs)
        
        # 6. Report
        drop_reasons = [ch for log in epochs.drop_log if log for ch in log if ch not in ['IGNORED', 'NO_DATA']]
        counts = Counter(drop_reasons)
        top_culprits = "; ".join([f"{ch}({n})" for ch, n in counts.most_common(3)])

        print(f"   Filter: {filt_type} | Ref: {ref}")
        print(f"   Survival: {n_after}/{n_before} | Top: {top_culprits if top_culprits else 'None'}")

        # 7. Save CSV
        summary_data = {
            "file": f_path.name,
            "filter": filt_type,
            "reference": ref,
            "remaining_epochs": n_after,
            "thr_esg": round(t_esg, 2),
            "top_culprits": top_culprits
        }
        pd.DataFrame([summary_data]).to_csv(REPORT_DIR / f"Cleaning_REST_{f_path.stem}.csv", index=False)

        # 8. Save Cleaned (Only Spinals)
        epochs_spinals = epochs.copy().pick_types(eeg=True)
        out_name = f"CLEANED_REST_{ref}_{filt_type}_SPINALS-epo.fif"
        epochs_spinals.save(OUT_DIR / out_name, overwrite=True, verbose=False)
        
        del epochs, epochs_spinals; gc.collect()

    print("\n--- REST SPINAL CLEANING COMPLETED ---")

if __name__ == "__main__":
    main_cleaning_rest_spinals()
